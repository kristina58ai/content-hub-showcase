# --- LLM providers (generation only; embeddings are local, ADR-017) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
# groq (default) | openrouter | fake (dev-only: no keys required, canned responses)
LLM_PRIMARY_PROVIDER=groq

# --- Embeddings (ADR-017: local, offline, no API key) ---
LOCAL_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
# local (default) | fake (tests)
EMBEDDING_PROVIDER=local

# --- LangGraph checkpointer (ADR-009) ---
# Dev: docker compose -f ../docker-compose.dev.yml up -d  ->  redis://localhost:6379
# Prod (HF Spaces): Upstash Redis Free connection string
REDIS_URL=redis://localhost:6379
CHECKPOINT_TTL_HOURS=24

# --- Security (mandatory, ADR-009: anti-RCE via checkpoint deserialization) ---
LANGGRAPH_STRICT_MSGPACK=true

# --- App ---
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
DATA_DIR=data
